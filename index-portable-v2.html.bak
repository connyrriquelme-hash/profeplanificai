<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>PlanificaIA Chile Portable v2</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<style>
:root{--bg:#0f1119;--bg2:#161822;--card:#1c1f2e;--card2:#232738;--ink:#e8edf5;--muted:#8892a8;--brand:#6d5dfc;--brand2:#00a7a7;--line:#2a2f42;--warn:#332e1a;--ok:#1a3328;--danger:#331a1a;--shadow:0 12px 32px rgba(0,0,0,.3);--radius:16px;--rs:12px}
*{box-sizing:border-box;margin:0;padding:0}
body{margin:0;font-family:Segoe UI,Roboto,Arial,sans-serif;background:var(--bg);color:var(--ink);min-height:100vh}
header{padding:16px 24px;display:flex;gap:14px;align-items:center;justify-content:space-between;position:sticky;top:0;background:rgba(15,17,25,.92);backdrop-filter:blur(14px);z-index:20;border-bottom:1px solid var(--line)}
.logo{display:flex;gap:12px;align-items:center}.badge{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--brand),var(--brand2));display:grid;place-items:center;color:#fff;font-weight:900;font-size:20px}
h1{font-size:18px;margin:0}.sub{font-size:11px;color:var(--muted)}
.pill{font-size:11px;padding:6px 12px;border-radius:999px;background:var(--card);border:1px solid var(--line);color:var(--muted)}
main{display:grid;grid-template-columns:220px minmax(0,1fr);gap:18px;padding:18px 24px 40px}
nav{position:sticky;top:82px;align-self:start}
.nav-btn{width:100%;border:0;background:transparent;border-radius:var(--rs);text-align:left;padding:10px 12px;margin:2px 0;font-weight:600;font-size:13px;color:var(--muted);cursor:pointer;display:flex;gap:8px;align-items:center}
.nav-btn:hover{background:rgba(109,93,252,.1);color:var(--ink)}
.nav-btn.active{background:linear-gradient(135deg,rgba(109,93,252,.2),rgba(0,167,167,.15));color:var(--brand2)}
.nav-icon{font-size:15px;width:20px;text-align:center}
.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:18px;margin-bottom:16px}
.card h2{font-size:17px;margin-bottom:12px}
.card h3{font-size:14px;margin-bottom:8px;color:var(--muted)}
.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.two-col{display:grid;grid-template-columns:1.1fr .9fr;gap:16px}
label{display:block;font-weight:600;font-size:11px;margin-bottom:5px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px}
input,select,textarea{width:100%;border:1px solid var(--line);border-radius:var(--rs);padding:9px 11px;font:inherit;font-size:13px;background:var(--bg2);color:var(--ink)}
textarea{min-height:70px;resize:vertical}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 3px rgba(109,93,252,.15)}
button{border:0;border-radius:var(--rs);padding:10px 14px;font-weight:700;font-size:12px;cursor:pointer;transition:all .15s}
.primary{background:linear-gradient(135deg,var(--brand),#8957ff);color:#fff}.primary:hover{opacity:.92;transform:translateY(-1px)}
.secondary{background:var(--card2);color:var(--ink);border:1px solid var(--line)}
.ghost{background:transparent;border:1px solid var(--line);color:var(--muted)}
.ghost:hover{background:var(--card2);color:var(--ink)}
.danger{background:var(--danger);color:#f87171;border:1px solid #4a1a1a}.danger:hover{background:#4a1a1a}
.btnrow{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.small{font-size:11px;padding:6px 10px;border-radius:9px}
.status{border-radius:var(--rs);padding:10px 12px;margin:10px 0;border:1px solid var(--line);background:var(--card2);color:var(--muted);font-size:12px}
.status.ok{background:var(--ok);border-color:#1a6b3c;color:#6ee7a0}
.status.warn{background:var(--warn);border-color:#6b5a1a;color:#f5d76e}
.status.bad{background:var(--danger);border-color:#6b1a1a;color:#f87171}
.output{background:#0b1220;color:#eef7ff;border-radius:var(--radius);padding:16px;min-height:180px;line-height:1.5;overflow:auto;font-size:13px;white-space:pre-wrap}
.output-light{background:var(--card2);color:var(--ink);border:1px solid var(--line)}
.output h1,.output h2,.output h3{color:#fff;margin:12px 0 6px}.output-light h1,.output-light h2,.output-light h3{color:var(--ink)}
.output h1{font-size:18px}.output h2{font-size:15px}.output h3{font-size:13px}
.output ul{padding-left:18px;margin:6px 0}.output li{margin:3px 0}.output b{color:var(--brand2)}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:16px}
.metric{padding:14px;border:1px solid var(--line);border-radius:var(--radius);background:var(--card);text-align:center}
.metric b{display:block;font-size:24px;color:var(--brand2);margin-bottom:3px}
.metric span{color:var(--muted);font-size:12px}
.muted{color:var(--muted);font-size:12px}
.resource-list{display:grid;gap:8px}
.resource-item{border:1px solid var(--line);border-radius:var(--rs);padding:10px;background:var(--card2)}
.resource-item b{display:block;margin-bottom:3px}
.banner{display:flex;gap:12px;align-items:flex-start;background:linear-gradient(135deg,rgba(109,93,252,.1),rgba(0,167,167,.08));border:1px solid rgba(109,93,252,.2);border-radius:var(--radius);padding:14px;margin-bottom:16px}
.hidden{display:none!important}
.search-bar{position:relative}.search-bar input{padding-left:32px}.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:13px}
.modal{position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:100}
.modal-c{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:20px;max-width:500px;width:90%;max-height:80vh;overflow-y:auto}
@media(max-width:900px){main{grid-template-columns:1fr}nav{position:static}.grid,.grid3,.two-col{grid-template-columns:1fr}header{flex-wrap:wrap;position:static}}
@media print{body{background:#fff!important;color:#000!important}header,nav,.no-print,.btnrow{display:none!important}main{display:block;padding:0}.card{box-shadow:none!important;border:1px solid #ddd!important}.output{background:#fff!important;color:#000!important;border:0!important}.output *{color:#000!important}.output b{color:#333!important}}
</style>
</head>
<body>
<header>
<div class="logo"><div class="badge">P</div><div><h1>PlanificaIA Chile</h1><div class="sub">Planificación, recursos, evaluaciones</div></div></div>
<span class="pill" id="pill">Modo local · sin API key</span>
</header>
<main>
<nav class="no-print" id="sidebar"></nav>
<section id="v-inicio" class="view"></section>
<section id="v-planificador" class="view hidden"></section>
<section id="v-recursos" class="view hidden"></section>
<section id="v-evaluaciones" class="view hidden"></section>
<section id="v-banco" class="view hidden"></section>
<section id="v-colaboracion" class="view hidden"></section>
<section id="v-drive" class="view hidden"></section>
<section id="v-config" class="view hidden"></section>
</main>
<script>
// ─── DATA ─────────────────────────────────────────────────────────────────
const NIVELES=['Prekinder','Kinder','1° básico','2° básico','3° básico','4° básico','5° básico','6° básico','7° básico','8° básico','1° medio','2° medio','3° medio','4° medio'];
const ASIG=['Lenguaje Verbal','Lenguaje Artístico','Exploración del Entorno Natural','Identidad y Autonomía','Convivencia y Ciudadanía','Lenguaje y Comunicación','Matemática','Ciencias Naturales','Historia, Geografía y Cs. Sociales','Inglés','Artes Visuales','Música','Educación Física','Tecnología','Orientación','Interdisciplinario'];
const DURACIONES=['45 minutos','60 minutos','90 minutos','2 clases de 45 minutos','Unidad de 4 clases'];
const ENFOQUES=['Comprensión lectora','Aprendizaje colaborativo','Proyecto interdisciplinario','DUA e inclusión','Preparación SIMCE','Evaluación formativa'];
const TIPOS_REC=['Guía imprimible','Presentación clase a clase','Infografía textual','Actividad colaborativa','Juego pedagógico','Rúbrica','Ticket de salida','Prompt para imagen IA','Prompt para video IA','Estructura PPT'];
const TIPOS_EVAL=['Evaluación diagnóstica','Evaluación formativa','Evaluación sumativa','Ensayo tipo SIMCE','Ticket de salida','Rúbrica analítica'];
const DIFICULTADES=['Progresiva','Básica','Intermedia','Avanzada'];
const OA_CURRICULARES=[
{codigo:'OA 1',nivel:'Prekinder',asig:'Lenguaje Verbal',desc:'Expresar ideas y emociones mediante palabras, gestos y movimientos en situaciones cotidianas.',habs:['Expresar','Comunicar']},
{codigo:'OA 2',nivel:'Prekinder',asig:'Lenguaje Verbal',desc:'Comprender narraciones orales breves respondiendo preguntas simples sobre personajes y acciones.',habs:['Comprender','Responder']},
{codigo:'OA 3',nivel:'Prekinder',asig:'Lenguaje Artístico',desc:'Explorar sonidos, ritmos y movimientos corporales como formas de expresión personal.',habs:['Explorar','Expresar']},
{codigo:'OA 4',nivel:'Prekinder',asig:'Exploración del Entorno Natural',desc:'Observar y describir elementos de la naturaleza usando los sentidos.',habs:['Observar','Describir']},
{codigo:'OA 5',nivel:'Prekinder',asig:'Identidad y Autonomía',desc:'Identificar emociones básicas propias y de otros en situaciones cotidianas.',habs:['Identificar','Reconocer']},
{codigo:'OA 6',nivel:'Prekinder',asig:'Convivencia y Ciudadanía',desc:'Participar en juegos y actividades grupales respetando turnos y normas simples.',habs:['Participar','Respetar']},
{codigo:'OA 1',nivel:'Kinder',asig:'Lenguaje Verbal',desc:'Producir textos orales coherentes sobre experiencias personales o narraciones, usando vocabulario variado.',habs:['Producir','Organizar','Narrar']},
{codigo:'OA 2',nivel:'Kinder',asig:'Lenguaje Verbal',desc:'Reconocer letras y sonidos asociados a su nombre y palabras significativas en su entorno.',habs:['Reconocer','Asociar']},
{codigo:'OA 3',nivel:'Kinder',asig:'Lenguaje Artístico',desc:'Representar creativamente ideas y emociones mediante dibujo, pintura, modelado y dramatización.',habs:['Representar','Crear']},
{codigo:'OA 4',nivel:'Kinder',asig:'Exploración del Entorno Natural',desc:'Formular preguntas y conjeturas sobre fenómenos naturales a partir de la observación.',habs:['Preguntar','Conjeturar']},
{codigo:'OA 5',nivel:'Kinder',asig:'Identidad y Autonomía',desc:'Tomar decisiones simples y resolver conflictos cotidianos con mediación y autonomía creciente.',habs:['Decidir','Resolver']},
{codigo:'OA 6',nivel:'Kinder',asig:'Convivencia y Ciudadanía',desc:'Colaborar en actividades colectivas asumiendo roles y responsabilidades básicas.',habs:['Colaborar','Asumir roles']},
{codigo:'OA 7',nivel:'Kinder',asig:'Exploración del Entorno Natural',desc:'Establecer relaciones de semejanza y diferencia entre elementos del entorno mediante clasificación y seriación.',habs:['Clasificar','Seriar','Comparar']},
{codigo:'OA 1',nivel:'1° básico',asig:'Lenguaje y Comunicación',desc:'Reconocer que los textos escritos transmiten mensajes y que se escriben y leen de izquierda a derecha.',habs:['Reconocer','Identificar']},
{codigo:'OA 2',nivel:'1° básico',asig:'Lenguaje y Comunicación',desc:'Comprender textos orales breves y sencillos, identificando información explícita.',habs:['Comprender','Identificar']},
{codigo:'OA 3',nivel:'1° básico',asig:'Matemática',desc:'Contar números del 0 al 100 de 1 en 1, de 2 en 2, de 5 en 5 y de 10 en 10.',habs:['Contar','Secuenciar']},
{codigo:'OA 4',nivel:'1° básico',asig:'Matemática',desc:'Leer, escribir y comparar números hasta el 100.',habs:['Leer','Escribir','Comparar']},
{codigo:'OA 5',nivel:'1° básico',asig:'Ciencias Naturales',desc:'Observar y describir características de seres vivos y distinguirlos de objetos no vivos.',habs:['Observar','Describir','Clasificar']},
{codigo:'OA 1',nivel:'2° básico',asig:'Lenguaje y Comunicación',desc:'Leer y comprender textos narrativos breves, localizando información explícita e infiriendo características de personajes.',habs:['Localizar','Inferir','Interpretar']},
{codigo:'OA 2',nivel:'2° básico',asig:'Lenguaje y Comunicación',desc:'Desarrollar vocabulario a partir de palabras nuevas en textos orales y escritos.',habs:['Ampliar vocabulario','Comprender']},
{codigo:'OA 3',nivel:'2° básico',asig:'Lenguaje y Comunicación',desc:'Escribir respuestas completas usando mayúscula, punto y conectores simples.',habs:['Escribir','Organizar ideas']},
{codigo:'OA 4',nivel:'2° básico',asig:'Matemática',desc:'Resolver problemas usando estrategias de conteo, representación pictórica, concreta y simbólica.',habs:['Resolver','Representar','Comunicar']},
{codigo:'OA 5',nivel:'2° básico',asig:'Matemática',desc:'Comunicar procedimientos matemáticos de forma oral, escrita y con representaciones.',habs:['Comunicar','Argumentar']},
{codigo:'OA 6',nivel:'2° básico',asig:'Ciencias Naturales',desc:'Observar, comparar y comunicar características de seres vivos, materiales o fenómenos naturales.',habs:['Observar','Comparar','Comunicar']},
{codigo:'OA 7',nivel:'2° básico',asig:'Historia, Geografía y Cs. Sociales',desc:'Ubicar acontecimientos en secuencias temporales y reconocer cambios y continuidades.',habs:['Ubicar','Secuenciar','Comparar']},
{codigo:'OA 1',nivel:'3° básico',asig:'Lenguaje y Comunicación',desc:'Leer y comprender textos literarios y no literarios, extrayendo información explícita e implícita.',habs:['Comprender','Extraer','Inferir']},
{codigo:'OA 2',nivel:'3° básico',asig:'Matemática',desc:'Resolver problemas rutinarios y no rutinarios que involucren adición, sustracción y multiplicación.',habs:['Resolver','Calcular','Verificar']},
{codigo:'OA 1',nivel:'4° básico',asig:'Lenguaje y Comunicación',desc:'Comprender textos narrativos y poemas, extrayendo información explícita e implícita.',habs:['Localizar','Inferir','Interpretar']},
{codigo:'OA 2',nivel:'4° básico',asig:'Matemática',desc:'Resolver problemas aplicando estrategias de cálculo mental y escrito.',habs:['Resolver','Calcular','Verificar']},
{codigo:'OA 3',nivel:'4° básico',asig:'Historia, Geografía y Cs. Sociales',desc:'Leer fuentes, imágenes o mapas simples para obtener información.',habs:['Interpretar','Analizar fuentes','Responder']},
{codigo:'OA 1',nivel:'5° básico',asig:'Lenguaje y Comunicación',desc:'Analizar textos narrativos y no narrativos, identificando estructura y propósito.',habs:['Analizar','Identificar','Interpretar']},
{codigo:'OA 2',nivel:'5° básico',asig:'Matemática',desc:'Resolver problemas que involucren fracciones, decimales y porcentajes.',habs:['Aplicar','Resolver','Modelar']},
{codigo:'OA 1',nivel:'6° básico',asig:'Lenguaje y Comunicación',desc:'Analizar textos narrativos identificando conflicto, personajes, ambiente y narrador.',habs:['Analizar','Interpretar','Evaluar']},
{codigo:'OA 2',nivel:'6° básico',asig:'Matemática',desc:'Aplicar operaciones con fracciones, decimales y porcentajes en resolución de problemas.',habs:['Aplicar','Calcular','Resolver']},
{codigo:'OA 1',nivel:'7° básico',asig:'Lenguaje y Comunicación',desc:'Interpretar textos literarios y no literarios analizando recursos expresivos y propósito.',habs:['Interpretar','Analizar','Evaluar']},
{codigo:'OA 2',nivel:'7° básico',asig:'Matemática',desc:'Utilizar números enteros y racionales en resolución de problemas cotidianos.',habs:['Utilizar','Operar','Resolver']},
{codigo:'OA 1',nivel:'8° básico',asig:'Lenguaje y Comunicación',desc:'Analizar críticamente textos evaluando argumentos, evidencias y recursos persuasivos.',habs:['Analizar críticamente','Evaluar','Argumentar']},
{codigo:'OA 2',nivel:'8° básico',asig:'Matemática',desc:'Modelar situaciones usando expresiones algebraicas y ecuaciones de primer grado.',habs:['Modelar','Resolver','Representar']},
{codigo:'OA 1',nivel:'1° medio',asig:'Lenguaje y Comunicación',desc:'Analizar e interpretar obras literarias considerando contexto, género y recursos estéticos.',habs:['Analizar','Interpretar','Contextualizar']},
{codigo:'OA 2',nivel:'1° medio',asig:'Matemática',desc:'Resolver problemas utilizando números reales, potencias y raíces.',habs:['Resolver','Aplicar','Calcular']},
{codigo:'OA 1',nivel:'2° medio',asig:'Lenguaje y Comunicación',desc:'Producir textos argumentativos y expositivos organizando ideas con coherencia.',habs:['Producir','Organizar','Argumentar']},
{codigo:'OA 2',nivel:'2° medio',asig:'Matemática',desc:'Analizar funciones lineales, afines y cuadráticas en forma algebraica y gráfica.',habs:['Analizar','Representar','Interpretar']},
{codigo:'OA 1',nivel:'3° medio',asig:'Lenguaje y Comunicación',desc:'Evaluar críticamente discursos considerando postura del emisor y recursos retóricos.',habs:['Evaluar críticamente','Analizar','Argumentar']},
{codigo:'OA 2',nivel:'3° medio',asig:'Matemática',desc:'Modelar situaciones usando funciones exponenciales, logarítmicas y trigonométricas.',habs:['Modelar','Aplicar','Analizar']},
{codigo:'OA 1',nivel:'4° medio',asig:'Lenguaje y Comunicación',desc:'Sintetizar y comunicar información de múltiples fuentes evaluando pertinencia y validez.',habs:['Sintetizar','Evaluar','Comunicar']},
{codigo:'OA 2',nivel:'4° medio',asig:'Matemática',desc:'Resolver problemas de probabilidad, estadística inferencial y toma de decisiones.',habs:['Resolver','Analizar datos','Decidir']}
];

// ─── UTILITIES ─────────────────────────────────────────────────────────────
const $=id=>document.getElementById(id);
const $$=(sel,ctx=document)=>ctx.querySelectorAll(sel);
const esc=s=>(s||'').replace(/[&<>]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[m]));
function md(t){let s=esc(t);s=s.replace(/^###(.*)$/gm,'<h3>$1</h3>').replace(/^##(.*)$/gm,'<h2>$1</h2>').replace(/^#(.*)$/gm,'<h1>$1</h1>').replace(/\*\*(.*?)\*\*/g,'<b>$1</b>').replace(/^- (.*)$/gm,'<li>$1</li>');s=s.replace(/(<li>.*<\/li>)/gs,'<ul>$1</ul>');return s.replace(/\n/g,'<br>')}
function genId(){return Date.now().toString(36)+Math.random().toString(36).slice(2,8)}
function ls(k,d){try{return JSON.parse(localStorage.getItem(k))||d}catch{return d}}
function lss(k,v){localStorage.setItem(k,JSON.stringify(v))}

// ─── OA CONTEXT ─────────────────────────────────────────────────────────────
function getOAs(nivel,asig){return OA_CURRICULARES.filter(o=>o.nivel===nivel&&o.asig===asig)}
function buildOAContext(nivel,asig,oaText){
  const ms=getOAs(nivel,asig);if(!ms.length)return'';
  let parts=['## Contexto curricular - OA vigentes en Chile'];
  const q=oaText.toLowerCase();const exact=ms.filter(o=>oaText.includes(o.codigo)||o.desc.toLowerCase().includes(q)||o.habs.some(h=>h.toLowerCase().includes(q)));
  const r=exact.length>0?exact:ms.slice(0,3);
  for(const o of r){parts.push('');parts.push('### '+o.codigo+' — '+o.asig+' — '+o.nivel);parts.push(o.desc);if(o.habs.length)parts.push('**Habilidades:** '+o.habs.join(', '))}
  if(r.length<ms.length)parts.push('','*Hay '+(ms.length-r.length)+' OA'+(ms.length-r.length>1?'s':'')+' más para '+nivel+' - '+asig+'. Se muestran los más relevantes.*');
  return parts.join('\n')
}

// ─── CONFIG ────────────────────────────────────────────────────────────────
function cfg(){return ls('planificaia_cfg',{provider:'local',model:'',apiKey:''})}
function saveCfg(c){lss('planificaia_cfg',c);updatePill()}
function updatePill(){const c=cfg();$('pill').textContent=c.provider==='local'?'Modo local · sin API key':`IA: ${c.provider}`}

// ─── STORAGE ───────────────────────────────────────────────────────────────
function getBank(){return ls('planificaia_bank',[])}
function saveBank(e){const a=getBank();a.unshift(e);lss('planificaia_bank',a);return a}
function delBank(id){const a=getBank().filter(x=>x.id!==id);lss('planificaia_bank',a);return a}
function getMats(){return ls('planificaia_materials',[])}
function saveMat(m){const a=getMats();const i=a.findIndex(x=>x.id===m.id);if(i>=0)a[i]=m;else a.unshift(m);lss('planificaia_materials',a);return a}
function delMat(id){const a=getMats().filter(x=>x.id!==id);lss('planificaia_materials',a);return a}
function getPosts(){return ls('planificaia_collab',[])}
function savePost(p){const a=getPosts();a.unshift(p);lss('planificaia_collab',a);return a}
function likePost(id){const a=getPosts();const p=a.find(x=>x.id===id);if(p)p.likes++;lss('planificaia_collab',a);return a}
function addCmt(pid,c){const a=getPosts();const p=a.find(x=>x.id===pid);if(p){p.comentarios=p.comentarios||[];p.comentarios.push(c)}lss('planificaia_collab',a);return a}
function delPost(id){const a=getPosts().filter(x=>x.id!==id);lss('planificaia_collab',a);return a}
function getDrive(){return ls('planificaia_drive',[])}
function saveDrive(d){const a=getDrive();a.unshift(d);lss('planificaia_drive',a);return a}
function delDrive(id){const a=getDrive().filter(x=>x.id!==id);lss('planificaia_drive',a);return a}

// ─── AI SERVICE ────────────────────────────────────────────────────────────
async function callAI(prompt){const c=cfg();if(c.provider==='local'||!c.apiKey)throw Error('Modo local');if(c.provider==='gemini'){const m=c.model||'gemini-2.0-flash';const r=await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${encodeURIComponent(m)}:generateContent?key=${encodeURIComponent(c.apiKey)}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contents:[{parts:[{text:prompt}]}],generationConfig:{temperature:.72}})});const d=await r.json();if(!r.ok)throw Error(d.error?.message||'Error Gemini');return(d.candidates?.[0]?.content?.parts||[]).map(p=>p.text||'').join('\n')||'Sin texto.'}
if(c.provider==='openrouter'){const m=c.model||'openrouter/auto';const r=await fetch('https://openrouter.ai/api/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+c.apiKey,'HTTP-Referer':location.href,'X-Title':'PlanificaIA Chile'},body:JSON.stringify({model,m,messages:[{role:'system',content:'Eres un asistente experto en planificación educativa chilena.'},{role:'user',content:prompt}],temperature:.72})});const d=await r.json();if(!r.ok)throw Error(d.error?.message||'Error OpenRouter');return d.choices?.[0]?.message?.content||'Sin texto.'}
if(c.provider==='huggingface'){const m=c.model||'meta-llama/Llama-3.1-8B-Instruct';const r=await fetch('https://router.huggingface.co/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+c.apiKey},body:JSON.stringify({model,m,messages:[{role:'user',content:prompt}],temperature:.72,max_tokens:1800})});const d=await r.json();if(!r.ok)throw Error(d.error?.message||d.message||'Error HF');return d.choices?.[0]?.message?.content||'Sin texto.'}
throw Error('Proveedor no soportado')}

// ─── LOCAL GENERATORS ─────────────────────────────────────────────────────
function oaHdr(nivel,asig,oaText){const ctx=buildOAContext(nivel,asig,oaText);return ctx?ctx+'\n\n---\n\n':''}
function esParv(n){return n==='Prekinder'||n==='Kinder'}
function genPlan(kind,d){const t=kind==='plan'?'Planificación de clase':'Secuencia de unidad';const h=oaHdr(d.nivel,d.asig,d.oa);
if(esParv(d.nivel))return h+[`# ${t} - Educación Parvularia`,'',`**Nivel:** ${d.nivel}`,`**Ámbito:** ${d.asig}`,`**Duración:** ${d.duracion}`,`**Enfoque:** ${d.enfoque}`,'','## Objetivo de Aprendizaje',d.oa||'OA pendiente BCEP.','','## Contexto del grupo',d.contexto||'Grupo heterogéneo.','','## Inicio (10-15 min)','1. Activación: canción o ronda de saludo.','2. Motivación: elemento sorpresa.','3. Presentación del propósito.','','## Desarrollo (20-25 min)','1. Experiencia práctica y lúdica.','2. Exploración con materiales concretos.','3. Mediación de la educadora.','4. Variación según ritmos.','','## Cierre (10 min)','1. Síntesis grupal.','2. Evaluación por observación.','3. Sugerencia para el hogar.','','## Evaluación formativa','- Indicadores observables.','- Pauta: Logrado / En Proceso / No Observado.','','## DUA y apoyos concretos','- Representación: imágenes, objetos, modelaje.','- Acción: manipulación, gestos, dibujo.','- Participación: juego, parejas, elección.','','## Recursos','- Material concreto, láminas, cuentos, canciones.'].join('\n');
return h+[`# ${t}`,'',`**Nivel:** ${d.nivel}`,`**Asignatura:** ${d.asig}`,`**Duración:** ${d.duracion}`,`**Enfoque:** ${d.enfoque}`,'','## Objetivo de aprendizaje',d.oa||'OA pendiente.','','## Contexto',d.contexto||'Curso heterogéneo.','','## Meta','Al finalizar podrán demostrar comprensión del objetivo.','','## Habilidades','- Comprender instrucciones.','- Trabajar colaborativamente.','- Justificar con evidencia.','','## Inicio','1. Activación de conocimientos previos.','2. Presentación del objetivo.','3. Vocabulario clave.','','## Desarrollo','1. Modelaje docente.','2. Práctica guiada en parejas.','3. Desafío colaborativo.','4. Pausa de metacognición.','','## Cierre','- Síntesis colectiva.','- Ticket de salida.','','## Evaluación formativa','- Lista de cotejo.','- Retroalimentación.','','## DUA y apoyos','- Representación: texto, imagen, audio.','- Acción: oral, escrita, dibujo.','- Participación: roles, elección.','','## Recursos','- Pizarra, texto, hoja de trabajo.','','## Adecuaciones','- Apoyo: pasos, banco de palabras.','- Desafío: preguntas inferenciales.'].join('\n')}
function genRec(d){const h=oaHdr(d.nivel,d.asig,d.oa);
if(esParv(d.nivel))return h+[`# ${d.tipo} - Educación Parvularia`,'',`**Nivel:** ${d.nivel}`,`**Ámbito:** ${d.asig}`,'','## OA / Contenido',d.oa||'Especificar OA BCEP.','','## Propósito pedagógico','Recurso para promover aprendizaje a través del juego, exploración y materiales concretos.','','## Material para la educadora','- Preparar el ambiente.','- Disponer materiales.','- Grupos pequeños.','','## Experiencia','### Inicio: Canción y presentación visual.','### Desarrollo: Actividad con materiales, preguntas de andamiaje.','### Cierre: Puesta en común, orden y despedida.','','## Apoyos DUA','- Representación: oral + visual.','- Acción: manipular, señalar, dibujar.','- Participación: elección, roles, parejas.','','## Pauta de observación','| Indicador | Logrado | En Proceso | No Obs. |','|----------|---------|------------|---------|','| Participa | | | |','| Sigue instrucciones | | | |','| Se expresa | | | |','| Interactúa | | | |'].join('\n');
if(d.tipo==='Rúbrica')return h+[`# ${d.tipo}`,'',`**Nivel:** ${d.nivel}`,`**Asignatura:** ${d.asig}`,'','## OA / contenido',d.oa||'Pega el OA exacto.','','## Criterios','| Criterio | Logrado (3) | Parcial (2) | Por lograr (1) | Puntaje |','|----------|-------------|-------------|----------------|---------|','| Comprensión | Completa | Parcial | No demuestra | |','| Aplicación | Correcta | Con apoyo | No aplica | |','| Comunicación | Clara | Parcial | No comunica | |','| Colab. | Activa | Con apoyo | No colabora | |'].join('\n');
return h+[`# ${d.tipo}`,'',`**Nivel:** ${d.nivel}`,`**Asignatura:** ${d.asig}`,'','## OA / contenido',d.oa||'Pega el OA exacto.','','## Propósito','Recurso para apoyar el aprendizaje con instrucciones claras y práctica gradual.','','## Material estudiantes','### 1. Antes: Lee instrucción, subraya palabras clave.','### 2. Actividad: Trabaja en pareja, resuelve, explica.','### 3. Desafío extra: Crea una pregunta nueva.','','## Apoyo DUA','- Versión oral.','- Dibujo, esquema o frase.','- Banco de palabras.','','## Pauta rápida','- 2 pts: correcta y justificada.','- 1 pt: parcial.','- 0 pt: no responde.','','## Necesidad',d.necesidad||'Ajustar según diagnóstico.'].join('\n')}
function genPrompts(d){const h=oaHdr(d.nivel,d.asig,d.oa);return h+[`# Prompts para IA gratuitos`,'',`## Prompt guía`,`Actúa como docente chileno/a experto/a en ${d.asig}. Crea una guía imprimible para ${d.nivel} sobre: ${d.oa}. Incluye objetivo, instrucciones, modelaje, práctica, ticket de salida, DUA y pauta. Contexto: ${d.necesidad}.`,'',`## Prompt imagen`,`Crea una imagen educativa clara y colorida para ${d.nivel} sobre ${d.oa}. Estilo amigable, diverso e inclusivo.`,'',`## Prompt presentación`,`Crea 6 diapositivas para enseñar ${d.oa} en ${d.nivel}: inicio, explicación, práctica guiada, colaborativa, individual y cierre.`,'',`## Prompt video`,`Guion de 60 segundos para explicar ${d.oa} a ${d.nivel}, lenguaje chileno neutro, ejemplos cotidianos y pregunta final.`].join('\n')}
function genEval(d){const h=oaHdr(d.nivel,d.asig,d.oa);
if(esParv(d.nivel))return h+[`# ${d.tipo} - Educación Parvularia`,'',`**Nivel:** ${d.nivel}`,`**Ámbito:** ${d.asig}`,'','## OA / Habilidad',d.oa||'OA BCEP.','','## Indicadores observables','1. Participa activamente.','2. Sigue instrucciones orales.','3. Se expresa con claridad.','4. Interactúa con pares.','5. Manifiesta curiosidad.','','## Pauta de observación','| Indicador | Logrado | En Proceso | No Obs. |','|----------|---------|------------|---------|','| Participación | □ | □ | □ |','| Instrucciones | □ | □ | □ |','| Expresión | □ | □ | □ |','| Interacción | □ | □ | □ |','| Curiosidad | □ | □ | □ |','','## Retroalimentación','- Logrado: elogio y nuevo desafío.','- En Proceso: mediación y apoyo.','- No Observado: repetir experiencia.'].join('\n');
const n=Math.max(3,Math.min(40,d.nPreg||10));const hs=['localizar','inferir','interpretar','evaluar','resolver','justificar'];let q='';for(let i=1;i<=n;i++){const h=hs[i%6];q+=`\n${i}. (${h}) Lee la situación y responde. ¿Cuál alternativa demuestra mejor el aprendizaje?\n   A) Distractor plausible.\n   B) Correcta.\n   C) Incompleta.\n   D) Fuera de foco.\n   Habilidad: ${h} | Respuesta: B | Retroalimentación: revisa la evidencia y justifica.\n`}
return h+[`# ${d.tipo}`,'',`**Nivel:** ${d.nivel}`,`**Asignatura:** ${d.asig}`,`**Dificultad:** ${d.dificultad||'Progresiva'}`,'',`## OA / habilidad`,d.oa||'OA pendiente.','',`## Texto base`,d.texto||'Texto creado por el/la docente según el contenido.','',`## Instrucciones`,`Lee con atención. Marca una alternativa por pregunta. Justifica dos respuestas.`,'',`## Preguntas`,q,'',`## Pauta`,`- 1 punto por alternativa correcta.`,'- 2 puntos por justificación clara.','',`## Análisis docente`,`Agrupa errores en: vocabulario, instrucciones, inferencia, procedimiento o justificación.`,'',`## Reenseñanza`,`1. Modelar pregunta difícil. 2. Comparar distractores. 3. Repetir con apoyo visual. 4. Ticket de salida.`].join('\n')}

// ─── GENERAR CON FALLBACK ──────────────────────────────────────────────────
function buildPrompt(kind,form){
  const oaCtx=buildOAContext(form.nivel,form.asig,form.oa||'');
  const ctxBlock=oaCtx?oaCtx+'\n\n---\n\n':'';
  const esParv=form.nivel==='Prekinder'||form.nivel==='Kinder';
  if(kind==='plan'||kind==='secuencia'){
    const d=form;const tipo=kind==='plan'?'planificación de clase':'secuencia de unidad';
    return ctxBlock+[
      `Eres un docente experto del currículum chileno. Crea una ${tipo} completa y contextualizada.`,
      `Nivel: ${d.nivel}`,`Asignatura/Ámbito: ${d.asig}`,`Duración: ${d.duracion}`,`Enfoque: ${d.enfoque}`,
      `OA: ${d.oa}`,`Contexto: ${d.contexto||'No especificado.'}`,`Extra: ${d.extra||'Ninguna.'}`,
      esParv?'Debe incluir: OA, ámbito, experiencia inicio-desarrollo-cierre, juego, DUA con apoyos concretos, evaluación por observación.':'Debe incluir: objetivo, habilidades, inicio-desarrollo-cierre, DUA, evaluación formativa, adecuaciones.',
      'Estructura con ##. Usa **negritas**. Sé específico y aplicable al aula chilena.'
    ].join('\n')
  }
  if(kind==='recurso'||kind==='prompts'){
    const d=form;
    if(kind==='prompts')return ctxBlock+[
      'Eres un docente chileno experto. Genera 4 prompts detallados para crear material pedagógico con IA.',
      `Nivel: ${d.nivel} | Asignatura/Ámbito: ${d.asig}`,`OA: ${d.oa}`,`Necesidad: ${d.necesidad||'No especificada.'}`,
      '1. Prompt para guía/taller 2. Prompt para imagen educativa 3. Prompt para PPT 4. Prompt para video corto.',
      'Cada prompt comienza con "Actúa como..." y es específico en nivel y contenido chileno.'
    ].join('\n');
    return ctxBlock+[
      'Eres un docente chileno experto. Crea un recurso pedagógico completo, imprimible y listo para usar.',
      `Tipo: ${d.tipo}`,`Nivel: ${d.nivel}`,`Asignatura/Ámbito: ${d.asig}`,`OA: ${d.oa}`,`Necesidad: ${d.necesidad||'No especificada.'}`,
      'Incluye: propósito, material docente, material estudiantes, DUA, pauta, adecuaciones. Usa ##.',
      esParv?'Adaptado a parvularia: lenguaje simple, actividades lúdicas, apoyos visuales concretos.':'Incluye actividades progresivas con DUA explícito.'
    ].join('\n')
  }
  const d=form;const esSIMCE=kind==='simce'||(d.tipo||'').toLowerCase().includes('simce');
  return ctxBlock+[
    `Eres un docente chileno experto en evaluación. Diseña ${esSIMCE?'un ensayo tipo SIMCE':'una evaluación'} contextualizada al currículum chileno.`,
    `Nivel: ${d.nivel}`,`Asignatura/Ámbito: ${d.asig}`,esParv?'':`N° preguntas: ${d.nPreg||10}`,`Dificultad: ${d.dificultad||'Progresiva'}`,
    `OA evaluado: ${d.oa}`,`Texto base: ${d.texto||'Crea uno apropiado.'}`,
    esParv?'Basada en observación: indicadores observables, pauta L/EP/NO, registro anecdótico, retroalimentación. NO usa preguntas escritas.':
    esSIMCE?'Formato SIMCE: alternativas A-D + desarrollo. Incluye pauta, análisis por habilidad, retroalimentación y reenseñanza.':
    'Incluye instrucciones, preguntas progresivas, pauta, rúbrica breve y retroalimentación por tipo de error.',
    'Usa ## y **negritas**. Sé específico y aplicable al aula chilena.'
  ].join('\n')
}
async function generar(kind,form,sid,oid){const st=$('s-'+sid),ot=$('o-'+oid);st.textContent='Generando...';st.className='status';
const prompt=buildPrompt(kind,form);
try{let text='';const c=cfg();if(c.provider!=='local'){try{text=await callAI(prompt);st.textContent='Generado con IA externa.';st.className='status ok'}catch(e){st.textContent='IA externa falló: '+e.message+'. Usando modo local.';st.className='status warn'}}
if(!text){if(kind==='plan'||kind==='secuencia')text=genPlan(kind,form);else if(kind==='recurso')text=genRec(form);else if(kind==='prompts')text=genPrompts(form);else text=genEval(form);if(!st.textContent.includes('falló')){st.textContent='Generado en modo local.';st.className='status ok'}}
ot.innerHTML=md(text);ot._md=text}catch(e){st.textContent='Error: '+e.message;st.className='status bad'}}

// ─── NAV / VIEWS ──────────────────────────────────────────────────────────
const VIEWS=['inicio','planificador','recursos','evaluaciones','banco','colaboracion','drive','config'];
const ICONS={inicio:'layout-dashboard',planificador:'clipboard-edit',recursos:'package',evaluaciones:'file-text',banco:'book-open',colaboracion:'users',drive:'folder',config:'settings'};
const LABELS={inicio:'Inicio rápido',planificador:'Planificador',recursos:'Generador recursos',evaluaciones:'Evaluaciones y SIMCE',banco:'Banco curricular',colaboracion:'Colaboración',drive:'Drive docente',config:'Conectar IA'};
let currentView='inicio';
function showView(v){currentView=v;VIEWS.forEach(x=>{$(v===x?'v-'+x:'v-'+x).classList.toggle('hidden',x!==v)});$$('.nav-btn').forEach(b=>b.classList.toggle('active',b.dataset.view===v));if(v==='banco')renderBank();if(v==='colaboracion')renderCollab();if(v==='drive')renderDrive();if(typeof lucide!=='undefined')lucide.createIcons()}
function initNav(){const sb=$('sidebar');sb.innerHTML=VIEWS.map(v=>`<button class="nav-btn${v==='inicio'?' active':''}" data-view="${v}" onclick="showView('${v}')"><span class="nav-icon"><i data-lucide="${ICONS[v]}" style="width:16px;height:16px"></i></span>${LABELS[v]}</button>`).join('')+'<div style="margin-top:auto;padding:8px;font-size:10px;color:var(--muted);text-align:center;border-top:1px solid var(--line);margin-top:12px;padding-top:10px" id="version">PlanificaIA v2.0.0 · portable</div>';if(typeof lucide!=='undefined')lucide.createIcons()}

// ─── RENDER VIEWS ─────────────────────────────────────────────────────────
function renderInicio(){ $('v-inicio').innerHTML=`
<div class="banner"><div style="font-size:26px"><i data-lucide="check-circle" style="width:28px;height:28px;color:var(--brand2)"></i></div><div><b>PlanificaIA Chile v2 está listo.</b><br><span class="muted">Crea planificaciones, evaluaciones, recursos DUA y rúbricas alineados al Currículum Nacional MINEDUC. Funciona sin conexión y sin API key.</span></div></div>
<div class="metrics"><div class="metric"><b>1</b><span>Selecciona nivel, asignatura y OA</span></div><div class="metric"><b>2</b><span>Genera materiales educativos</span></div><div class="metric"><b>3</b><span>Copia, descarga o imprime en PDF</span></div></div>
<div class="card"><h2>Qué puedes hacer</h2><ul style="padding-left:18px;line-height:1.8">${['Planificaciones clase a clase con DUA','Guías, rúbricas, tickets de salida y PPT','Evaluaciones tipo SIMCE con pauta','Recursos DUA y actividades colaborativas','Exportar a HTML, PDF o copiar al portapapeles','Colaborar con otros docentes','Drive personal de documentos'].map(x=>`<li><b>${x}</b></li>`).join('')}</ul><div class="btnrow"><button class="primary" onclick="showView('planificador')">Crear planificación</button><button class="secondary" onclick="showView('recursos')">Crear recurso</button><button class="ghost" onclick="showView('config')">Configurar IA</button></div></div>
<div class="card" style="border-color:rgba(245,215,110,.3)"><b style="display:inline-flex;align-items:center;gap:4px"><i data-lucide="pin" style="width:14px;height:14px"></i> Nota:</b> <span class="muted">Los OA son referenciales. Para uso formal, pega el OA ministerial exacto desde tus bases curriculares.</span></div>`}

// ─── PLANIFICADOR ─────────────────────────────────────────────────────────
function renderPlanificador(){ $('v-planificador').innerHTML=`
<div class="two-col"><div class="card"><h2>Planificador de clases</h2>
<div class="grid"><div><label>Nivel</label><select id="pNivel">${NIVELES.map(x=>`<option${x==='2° básico'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Asignatura</label><select id="pAsig" onchange="syncOA()">${ASIG.map(x=>`<option${x==='Lenguaje y Comunicación'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Duración</label><select id="pDur">${DURACIONES.map(x=>`<option${x==='90 minutos'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Enfoque</label><select id="pEnf">${ENFOQUES.map(x=>`<option${x==='Comprensión lectora'?' selected':''}>${x}</option>`).join('')}</select></div></div>
<label>OA / Indicador</label><textarea id="pOA" placeholder="Pega el OA ministerial..."></textarea>
<label>Contexto del curso</label><textarea id="pCtx" placeholder="Ej.: curso heterogéneo, estudiantes descendidos en lectura..."></textarea>
<label>Extra</label><textarea id="pExtra" placeholder="Ej.: incluir DUA, lectura guiada, trabajo en parejas..."></textarea>
<div class="btnrow"><button class="primary" onclick="genPlanView('plan')">Generar planificación</button><button class="secondary" onclick="genPlanView('secuencia')">Generar secuencia</button><button class="ghost" onclick="ejemploPlan()">Usar ejemplo</button></div></div>
<div class="card no-print"><h3>OA curriculares</h3><div class="search-bar" style="margin-bottom:8px"><span class="search-icon"><i data-lucide="search" style="width:14px;height:14px"></i></span><input id="oaSearch" placeholder="Buscar OA..." oninput="syncOA()"></div><div id="oaList" class="resource-list"></div></div></div>
<div class="card"><h2>Resultado</h2><div id="s-plan" class="status">Completa los campos y presiona generar.</div><div id="o-plan" class="output output-light"></div>
<div class="btnrow no-print"><button class="secondary" onclick="copiar('o-plan')">Copiar</button><button class="ghost" onclick="descargar('o-plan','planificacion.html')">HTML</button><button class="ghost" onclick="window.print()">PDF</button><button class="primary" onclick="guardarMat('planificacion','o-plan')">Guardar</button><button class="danger" onclick="limpiar('o-plan','s-plan','Completa los campos.')">Limpiar</button></div></div>`}
function syncOA(){const asig=$('pAsig').value;const q=$('oaSearch').value.toLowerCase();let items=OA_CURRICULARES.filter(o=>o.asig===asig);if(q)items=items.filter(o=>o.desc.toLowerCase().includes(q)||o.codigo.toLowerCase().includes(q));$('oaList').innerHTML=items.length?items.map(o=>`<div class="resource-item"><b>${o.codigo} · ${o.nivel}</b><p style="font-size:12px;color:var(--muted);margin:3px 0">${o.desc}</p><div class="btnrow"><button class="small secondary" onclick="setOA('${esc(o.desc).replace(/'/g,"\\'")}')">Usar</button></div></div>`).join(''):'<span class="muted">Sin resultados</span>'}
function setOA(t){$('pOA').value=t}
function ejemploPlan(){$('pNivel').value='2° básico';$('pAsig').value='Lenguaje y Comunicación';$('pDur').value='90 minutos';$('pEnf').value='Comprensión lectora';$('pOA').value='Leer y comprender textos narrativos breves, localizando información explícita e infiriendo características de personajes.';$('pCtx').value='Curso heterogéneo con distintos niveles de fluidez lectora.';$('pExtra').value='Incluir DUA, roles de equipo y ticket de salida.';syncOA()}
async function genPlanView(kind){const form={nivel:$('pNivel').value,asig:$('pAsig').value,duracion:$('pDur').value,enfoque:$('pEnf').value,oa:$('pOA').value,contexto:$('pCtx').value,extra:$('pExtra').value};await generar(kind,form,'plan','plan')}

// ─── RECURSOS ──────────────────────────────────────────────────────────────
function renderRecursos(){ $('v-recursos').innerHTML=`
<div class="card"><div class="grid3"><div><label>Tipo</label><select id="rTipo">${TIPOS_REC.map(x=>`<option${x==='Guía imprimible'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Nivel</label><select id="rNivel">${NIVELES.map(x=>`<option${x==='2° básico'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Asignatura</label><select id="rAsig">${ASIG.map(x=>`<option${x==='Lenguaje y Comunicación'?' selected':''}>${x}</option>`).join('')}</select></div></div>
<label>OA / contenido</label><textarea id="rOA" placeholder="Ej.: Comprender textos narrativos..."></textarea>
<label>Necesidad pedagógica</label><textarea id="rNec" placeholder="Ej.: estudiantes con bajo desempeño lector..."></textarea>
<div class="btnrow"><button class="primary" onclick="genRecView('recurso')">Generar recurso</button><button class="secondary" onclick="genRecView('prompts')">Generar prompts IA</button></div></div>
<div class="card"><h2>Resultado</h2><div id="s-rec" class="status">El modo local está listo.</div><div id="o-rec" class="output output-light"></div>
<div class="btnrow no-print"><button class="secondary" onclick="copiar('o-rec')">Copiar</button><button class="ghost" onclick="descargar('o-rec','recurso.html')">HTML</button><button class="ghost" onclick="window.print()">PDF</button><button class="primary" onclick="guardarMat('recurso','o-rec')">Guardar</button><button class="danger" onclick="limpiar('o-rec','s-rec','El modo local está listo.')">Limpiar</button></div></div>`}
async function genRecView(kind){const form={tipo:$('rTipo').value,nivel:$('rNivel').value,asig:$('rAsig').value,oa:$('rOA').value,necesidad:$('rNec').value};await generar(kind,form,'rec','rec')}

// ─── EVALUACIONES ──────────────────────────────────────────────────────────
function renderEvaluaciones(){ $('v-evaluaciones').innerHTML=`
<div class="card"><div class="grid3"><div><label>Tipo</label><select id="eTipo">${TIPOS_EVAL.map(x=>`<option${x==='Evaluación formativa'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Nivel</label><select id="eNivel">${NIVELES.map(x=>`<option${x==='2° básico'?' selected':''}>${x}</option>`).join('')}</select></div>
<div><label>Asignatura</label><select id="eAsig">${ASIG.map(x=>`<option${x==='Lenguaje y Comunicación'?' selected':''}>${x}</option>`).join('')}</select></div></div>
<div class="grid"><div><label>N° preguntas</label><input id="eNP" type="number" min="3" max="40" value="10"></div>
<div><label>Dificultad</label><select id="eDif">${DIFICULTADES.map(x=>`<option${x==='Progresiva'?' selected':''}>${x}</option>`).join('')}</select></div></div>
<label>OA / habilidad</label><textarea id="eOA" placeholder="Ej.: localizar información explícita, inferir..."></textarea>
<label>Texto base o tema</label><textarea id="eTexto" placeholder="Pega un texto breve o indica tema."></textarea>
<div class="btnrow"><button class="primary" onclick="genEvalView('evaluacion')">Generar evaluación</button><button class="secondary" onclick="genEvalView('simce')">Generar mini SIMCE</button></div></div>
<div class="card"><h2>Resultado</h2><div id="s-eval" class="status">Genera una evaluación editable.</div><div id="o-eval" class="output output-light"></div>
<div class="btnrow no-print"><button class="secondary" onclick="copiar('o-eval')">Copiar</button><button class="ghost" onclick="descargar('o-eval','evaluacion.html')">HTML</button><button class="ghost" onclick="window.print()">PDF</button><button class="primary" onclick="guardarMat('evaluacion','o-eval')">Guardar</button><button class="danger" onclick="limpiar('o-eval','s-eval','Genera una evaluación editable.')">Limpiar</button></div></div>`}
async function genEvalView(kind){const tipo=kind==='simce'?'Ensayo tipo SIMCE':$('eTipo').value;const form={tipo,nivel:$('eNivel').value,asig:$('eAsig').value,nPreg:parseInt($('eNP').value)||10,dificultad:$('eDif').value,oa:$('eOA').value,texto:$('eTexto').value};await generar('eval',form,'eval','eval')}

// ─── BANCO CURRICULAR ─────────────────────────────────────────────────────
function renderBanco(){ $('v-banco').innerHTML=`
<div class="two-col"><div class="card"><h2>Banco curricular</h2><p class="muted">Busca OA, guarda tus favoritos.</p>
<div class="search-bar" style="margin-bottom:8px"><span class="search-icon"><i data-lucide="search" style="width:14px;height:14px"></i></span><input id="bSearch" placeholder="Buscar OA..." oninput="renderBancoList()"></div>
<div class="grid" style="margin-bottom:10px"><div><label>Nivel</label><select id="bNivel" onchange="renderBancoList()"><option value="">Todos</option>${NIVELES.map(x=>`<option>${x}</option>`).join('')}</select></div>
<div><label>Asignatura</label><select id="bAsig" onchange="renderBancoList()"><option value="">Todas</option>${ASIG.map(x=>`<option>${x}</option>`).join('')}</select></div></div>
<div id="bancoList" class="resource-list" style="max-height:400px;overflow-y:auto"></div></div>
<div><div class="card"><h2>Agregar al banco personal</h2><div class="grid"><div><label>Título</label><input id="bTit" placeholder="Ej.: 2° básico Lenguaje OA1"></div><div><label>Etiqueta</label><input id="bTag" placeholder="Lenguaje, SIMCE..."></div></div><label>Contenido</label><textarea id="bText" placeholder="Pega OA, indicadores..."></textarea>
<div class="btnrow"><button class="primary" onclick="guardarBanco()">Guardar</button><button class="ghost" onclick="exportBanco()">Exportar JSON</button><button class="danger" onclick="if(confirm('¿Borrar todo?')){localStorage.removeItem('planificaia_bank');renderBancoB()}">Borrar</button></div></div>
<div class="card"><h2>Mis registros</h2><div id="bancoB" class="resource-list"></div></div></div></div>`;renderBancoList();renderBancoB()}
function renderBancoList(){const q=$('bSearch').value.toLowerCase();const n=$('bNivel').value;const a=$('bAsig').value;let items=OA_CURRICULARES;if(n)items=items.filter(o=>o.nivel===n);if(a)items=items.filter(o=>o.asig===a);if(q)items=items.filter(o=>o.desc.toLowerCase().includes(q)||o.codigo.toLowerCase().includes(q));$('bancoList').innerHTML=items.length?items.map(o=>`<div class="resource-item"><b>${o.codigo} · ${o.nivel} · ${o.asig}</b><p style="font-size:12px;color:var(--muted)">${o.desc}</p><div class="btnrow"><button class="small secondary" onclick="useOA('${esc(o.desc).replace(/'/g,"\\'")}')">Usar</button><button class="small ghost" onclick="saveOA('${esc(o.desc).replace(/'/g,"\\'")}','${esc(o.codigo+' · '+o.asig).replace(/'/g,"\\'")}','${o.nivel}')">Guardar</button></div></div>`).join(''):'<span class="muted">Sin resultados</span>'}
function useOA(t){$('pOA').value=t;showView('planificador')}
function saveOA(t,tit,nivel){$('bTit').value=tit;$('bText').value=t;$('bTag').value=nivel}
function renderBancoB(){const a=getBank();$('bancoB').innerHTML=a.length?a.map(x=>`<div class="resource-item"><b>${esc(x.title)}</b><span class="muted">${esc(x.tag)} · ${x.date}</span><p style="font-size:12px;margin-top:4px;color:var(--muted)">${esc(x.text).slice(0,300)}</p><div class="btnrow"><button class="small secondary" onclick="useOA('${esc(x.text).replace(/'/g,"\\'")}')">Usar</button><button class="small danger" onclick="delBanco('${x.id}')">Eliminar</button></div></div>`).join(''):'<p class="muted">Sin registros.</p>'}
function guardarBanco(){const title=$('bTit').value||'Sin título';const tag=$('bTag').value||'General';const text=$('bText').value;if(!text.trim())return;saveBank({id:genId(),title,tag,text,date:new Date().toLocaleString('es-CL')});$('bTit').value='';$('bTag').value='';$('bText').value='';renderBancoB()}
function delBanco(id){delBank(id);renderBancoB()}
function exportBanco(){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(getBank(),null,2)],{type:'application/json'}));a.download='banco-curricular.json';a.click()}

// ─── COLABORACIÓN ──────────────────────────────────────────────────────────
function renderColaboracion(){ $('v-colaboracion').innerHTML=`
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px"><h2 style="font-size:17px">Colaboración docente</h2><button class="primary small" onclick="mostrarFormPub()">+ Publicar</button></div>
<div id="pubModal" class="modal hidden"><div class="modal-c"><h3>Nueva publicación</h3>
<div class="grid"><div><label>Nombre</label><input id="pubUser" placeholder="Docente"></div><div><label>Tipo</label><select id="pubTipo">${['Planificación','Guía','Evaluación','Rúbrica','Actividad','Recurso DUA','Otro'].map(x=>`<option>${x}</option>`).join('')}</select></div>
<div><label>Nivel</label><select id="pubNivel"><option value="">Selec.</option>${NIVELES.map(x=>`<option>${x}</option>`).join('')}</select></div>
<div><label>Asignatura</label><select id="pubAsig"><option value="">Selec.</option>${ASIG.map(x=>`<option>${x}</option>`).join('')}</select></div></div>
<label>Título</label><input id="pubTit" placeholder="Título del recurso"><label>Contenido</label><textarea id="pubCont" style="min-height:100px" placeholder="Comparte tu material..."></textarea>
<div class="btnrow"><button class="primary" onclick="publicar()">Publicar</button><button class="ghost" onclick="cerrarPub()">Cancelar</button></div></div></div>
<div class="card"><div style="margin-bottom:10px"><input id="pubSearch" placeholder="Buscar publicaciones..." oninput="renderPubList()"></div><div id="pubList" class="resource-list"></div></div>`;renderPubList()}
function mostrarFormPub(){$('pubModal').classList.remove('hidden')}
function cerrarPub(){$('pubModal').classList.add('hidden')}
function publicar(){const post={id:genId(),usuario:$('pubUser').value||'Docente anónimo',titulo:$('pubTit').value,tipo:$('pubTipo').value,nivel:$('pubNivel').value,asignatura:$('pubAsig').value,contenido:$('pubCont').value,fecha:new Date().toLocaleString('es-CL'),likes:0,comentarios:[]};savePost(post);cerrarPub();$('pubTit').value='';$('pubCont').value='';renderPubList()}
function renderPubList(){const q=$('pubSearch')?.value.toLowerCase()||'';let posts=getPosts();if(q)posts=posts.filter(p=>p.titulo.toLowerCase().includes(q)||p.contenido.toLowerCase().includes(q));$('pubList').innerHTML=posts.length?posts.map(p=>`<div class="resource-item"><div style="display:flex;justify-content:space-between"><div><b>${esc(p.titulo)}</b><span class="muted" style="font-size:11px;display:block">${esc(p.usuario)} · ${p.tipo}${p.nivel?' · '+p.nivel:''}${p.asignatura?' · '+p.asignatura:''} · ${p.fecha}</span></div></div>
<div style="font-size:12px;margin:6px 0;color:var(--muted)">${esc(p.contenido).slice(0,500)}</div>
<div class="btnrow"><button class="small secondary" onclick="likePub('${p.id}')" style="display:inline-flex;align-items:center;gap:4px"><i data-lucide="thumbs-up" style="width:14px;height:14px"></i> ${p.likes}</button><button class="small danger" onclick="delPub('${p.id}')">Eliminar</button></div>
<div style="margin-top:6px;border-top:1px solid var(--line);padding-top:6px">${(p.comentarios||[]).map(c=>`<div style="font-size:11px;margin-bottom:4px;color:var(--muted)"><b>${esc(c.usuario)}</b>: ${esc(c.texto)} <span style="font-size:10px">${c.fecha}</span></div>`).join('')}
<div style="display:flex;gap:6px;margin-top:4px"><input id="cmt-${p.id}" placeholder="Comentar..." style="flex:1;font-size:11px;padding:4px 8px" onkeydown="if(event.key==='Enter')comentar('${p.id}')"><button class="small primary" onclick="comentar('${p.id}')">Enviar</button></div></div></div>`).join(''):'<p class="muted">Sin publicaciones. ¡Sé el primero!</p>'}
function likePub(id){likePost(id);renderPubList()}
function delPub(id){if(confirm('Eliminar?')){delPost(id);renderPubList()}}
function comentar(id){const inp=$('cmt-'+id);if(!inp||!inp.value.trim())return;addCmt(id,{id:genId(),usuario:'Docente',texto:inp.value,fecha:new Date().toLocaleString('es-CL')});inp.value='';renderPubList()}

// ─── DRIVE ─────────────────────────────────────────────────────────────────
function renderDrive(){ $('v-drive').innerHTML=`
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px"><h2 style="font-size:17px">Drive docente</h2><div class="btnrow" style="margin:0"><button class="secondary small" onclick="importMats()">Importar materiales</button><button class="primary small" onclick="mostrarSubir()">+ Subir</button></div></div>
<div id="subirModal" class="modal hidden"><div class="modal-c"><h3>Subir documento</h3><div class="grid"><div><label>Nombre</label><input id="dName" placeholder="Nombre"></div><div><label>Tipo</label><select disabled><option>Documento</option></select></div>
<div><label>Nivel</label><select id="dNivel"><option value="">Selec.</option>${NIVELES.map(x=>`<option>${x}</option>`).join('')}</select></div>
<div><label>Asignatura</label><select id="dAsig"><option value="">Selec.</option>${ASIG.map(x=>`<option>${x}</option>`).join('')}</select></div></div>
<label>Contenido</label><textarea id="dCont" style="min-height:100px" placeholder="Contenido..."></textarea>
<div class="btnrow"><button class="primary" onclick="subirDoc()">Guardar</button><button class="ghost" onclick="cerrarSubir()">Cancelar</button></div></div></div>
<div class="card"><div style="margin-bottom:10px"><input id="dSearch" placeholder="Buscar documentos..." oninput="renderDriveList()"></div><div id="driveList" class="resource-list"></div></div>`;renderDriveList()}
function mostrarSubir(){$('subirModal').classList.remove('hidden')}
function cerrarSubir(){$('subirModal').classList.add('hidden')}
function subirDoc(){const n=$('dName').value;const c=$('dCont').value;if(!n.trim()||!c.trim())return;saveDrive({id:genId(),nombre:n,tipo:'documento',contenido:c,nivel:$('dNivel').value,asignatura:$('dAsig').value,fecha:new Date().toLocaleString('es-CL'),tamano:c.length});cerrarSubir();$('dName').value='';$('dCont').value='';renderDriveList()}
function importMats(){getMats().forEach(m=>{if(!getDrive().some(i=>i.nombre===m.titulo))saveDrive({id:genId(),nombre:m.titulo,tipo:'material',contenido:m.contenido||'',nivel:m.nivel||'',asignatura:m.asignatura||'',fecha:new Date().toLocaleString('es-CL'),tamano:(m.contenido||'').length})});renderDriveList()}
function renderDriveList(){const q=$('dSearch')?.value.toLowerCase()||'';let items=getDrive();if(q)items=items.filter(i=>i.nombre.toLowerCase().includes(q)||i.nivel.toLowerCase().includes(q)||i.asignatura.toLowerCase().includes(q));$('driveList').innerHTML=items.length?items.map(i=>`<div class="resource-item"><b style="display:inline-flex;align-items:center;gap:4px"><i data-lucide="file-text" style="width:16px;height:16px"></i> ${esc(i.nombre)}</b><span class="muted" style="display:block;font-size:11px">${i.nivel||'Sin nivel'} · ${i.asignatura||'Sin asig'} · ${i.fecha} · ${(i.tamano/1024).toFixed(1)}KB</span><p style="font-size:12px;color:var(--muted);margin:4px 0;max-height:50px;overflow:hidden">${esc(i.contenido).slice(0,200)}${i.contenido.length>200?'...':''}</p><div class="btnrow"><button class="small secondary" onclick="descargarDoc('${esc(i.contenido).replace(/'/g,"\\'")}','${esc(i.nombre).replace(/'/g,"\\'")}')">Descargar</button><button class="small danger" onclick="if(confirm('Eliminar?')){delDrive('${i.id}');renderDriveList()}">Eliminar</button></div></div>`).join(''):'<p class="muted">Drive vacío. Sube documentos o impórtalos.</p>'}
function descargarDoc(con,nom){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([con],{type:'text/plain'}));a.download=nom.replace(/[^a-zA-Z0-9áéíóúñ ]/g,'')+'.txt';a.click()}

// ─── CONFIG ────────────────────────────────────────────────────────────────
function renderConfig(){const c=cfg();$('v-config').innerHTML=`
<div class="card"><h2>Conectar IA gratuita</h2><p class="muted" style="margin-bottom:10px">La app funciona sin clave. Si agregas API key, se guarda en este navegador. Si falla, vuelve a modo local.</p>
<div class="grid"><div><label>Proveedor</label><select id="cfgProv">${[{v:'local',l:'Local sin clave'},{v:'gemini',l:'Gemini API'},{v:'openrouter',l:'OpenRouter'},{v:'huggingface',l:'Hugging Face'}].map(p=>`<option value="${p.v}"${c.provider===p.v?' selected':''}>${p.l}</option>`).join('')}</select></div>
<div><label>Modelo</label><input id="cfgModel" value="${esc(c.model)}" placeholder="Ej.: gemini-2.0-flash"></div></div>
<label>API key</label><input id="cfgKey" type="password" value="${esc(c.apiKey)}" placeholder="API key del proveedor">
<div class="btnrow"><button class="primary" onclick="guardarCfg()">Guardar</button><button class="secondary" onclick="probarCfg()">Probar IA</button><button class="danger" onclick="resetCfg()">Modo local</button></div>
<div id="s-cfg" class="status">${c.provider==='local'?'Modo local activo.':'Configuración guardada.'}</div></div>
<div class="card"><h3>Generadores externos gratuitos</h3><ul style="padding-left:18px;line-height:1.8;color:var(--muted);font-size:13px">${['Google AI Studio / Gemini','Hugging Face Spaces','Canva / Adobe Express','Copilot / ChatGPT Free'].map(x=>`<li>${x}</li>`).join('')}</ul></div>`}
function guardarCfg(){const c={provider:$('cfgProv').value,model:$('cfgModel').value.trim(),apiKey:$('cfgKey').value.trim()};saveCfg(c);$('s-cfg').textContent=c.provider==='local'?'Modo local guardado.':'Configuración guardada.';$('s-cfg').className='status ok'}
function resetCfg(){localStorage.removeItem('planificaia_cfg');$('cfgProv').value='local';$('cfgModel').value='';$('cfgKey').value='';updatePill();$('s-cfg').textContent='Modo local activado.';$('s-cfg').className='status ok'}
async function probarCfg(){guardarCfg();$('s-cfg').textContent='Probando...';$('s-cfg').className='status';try{const r=await callAI('Responde: PlanificaIA conectada.');$('s-cfg').textContent='[OK] '+r.slice(0,250);$('s-cfg').className='status ok'}catch(e){$('s-cfg').textContent='[ERROR] '+e.message;$('s-cfg').className='status bad'}}

// ─── COMMON ACTIONS ────────────────────────────────────────────────────────
function copiar(id){const el=$('o-'+id)||$(id);navigator.clipboard.writeText(el._md||el.innerText).then(()=>alert('Copiado.'))}
function descargar(id,nombre){const el=$('o-'+id)||$(id);const html='<!doctype html><meta charset="utf-8"><body style="font-family:Arial;padding:2cm;line-height:1.5">'+el.innerHTML+'</body>';const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([html],{type:'text/html'}));a.download=nombre;a.click()}
function limpiar(oid,sid,msg){$(oid==='o-'?oid:'o-'+oid).innerHTML='';$(sid==='s-'?sid:'s-'+sid).textContent=msg;$('s-'+(sid.replace('s-',''))).className='status'}
function guardarMat(tipo,oid){const el=$(oid);const md=el._md||el.innerText;if(!md)return;saveMat({id:genId(),tipo,titulo:tipo.charAt(0).toUpperCase()+tipo.slice(1)+' - '+new Date().toLocaleDateString('es-CL'),contenido:md,nivel:'',asignatura:'',oa:'',fecha:new Date().toISOString(),etiquetas:[]});const st=$('s-'+oid.replace('o-',''));if(st){st.textContent='[OK] Guardado en Mis materiales.';st.className='status ok'}}

// ─── MATERIALES GUARDADOS ──────────────────────────────────────────────────
function renderMateriales(vista){const mats=getMats().filter(m=>m.tipo===vista||vista==='todos');return mats.length?mats.map(m=>`<div class="resource-item"><b>${esc(m.titulo)}</b><span class="muted" style="font-size:11px">${new Date(m.fecha).toLocaleString('es-CL')}</span><div class="btnrow"><button class="small secondary">Cargar</button><button class="small danger" onclick="delMat('${m.id}')">Eliminar</button></div></div>`).join(''):'<p class="muted">Sin materiales guardados.</p>'}

// ─── INIT ──────────────────────────────────────────────────────────────────
function init(){initNav();renderInicio();renderPlanificador();renderRecursos();renderEvaluaciones();renderBanco();renderColaboracion();renderDrive();renderConfig();updatePill();syncOA();if(typeof lucide!=='undefined')lucide.createIcons()}
document.addEventListener('DOMContentLoaded',init);
</script>
</body>
</html>
