{
  "name": "planificaia-chile",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Plataforma docente chilena para crear planificaciones, guías, evaluaciones, rúbricas y recursos DUA alineados al Currículum Nacional MINEDUC.",
  "scripts": {
    "dev": "vite",
    "local:setup": "wrangler d1 migrations apply planificaia-db --local",
    "local:dev": "npm run build && wrangler pages dev dist --port 8788",
    "local:check": "npm test && npm run build && wrangler pages functions build --outdir .wrangler-local-check",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "server": "tsx server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:curriculum": "node scripts/import-curriculum.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tiptap/extension-highlight": "^2.11.7",
    "@tiptap/extension-text-align": "^2.11.7",
    "@tiptap/extension-underline": "^2.11.7",
    "@tiptap/react": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "dotenv": "^17.4.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.41.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.104.0"
  }
}
